# Copy to .env.local for local dev. On Vercel, set these as project env vars.

# FastAPI backend base URL (no trailing slash).
ASO_API_BASE=https://aso-intelligence-api.onrender.com

# Matches the backend's ASO_API_KEY (protects POST endpoints). Leave empty if
# the backend doesn't enforce one. Server-only — never sent to the browser.
ASO_API_KEY=
