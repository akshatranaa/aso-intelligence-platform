# Copy this file to .env and fill in real values. Never commit .env itself.

# Required — Postgres connection string (e.g. from Neon). Format:
# postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Required for LLM features (seeds, sentiment, competitor judge, recommendations, use_llm=True)
# Get a free key at https://aistudio.google.com — the model is set in config.py (LLM_MODEL)
GEMINI_API_KEY=

# Optional — Apple Search Ads OAuth (Week 3 features only)
SEARCH_ADS_CLIENT_ID=
SEARCH_ADS_TEAM_ID=
SEARCH_ADS_KEY_ID=
SEARCH_ADS_PRIVATE_KEY_PATH=

# Optional — protects POST /collect from public abuse once deployed.
# Leave unset for local dev (no protection, matches current behaviour).
ASO_API_KEY=

# Optional — restricts CORS to your deployed dashboard's URL once you have one.
# Comma-separated. Leave unset (defaults to "*") for local dev.
ASO_ALLOWED_ORIGINS=

# Dashboard only — set this to your deployed FastAPI URL once the backend is live.
# Leave unset for local dev (defaults to http://localhost:8000).
ASO_API_BASE=
